<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Alan.Sortify.App.FormatBadge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border x:Name="BadgeBorder" Padding="8,2" CornerRadius="5"
            BorderThickness="1">
        <TextBlock x:Name="BadgeText"
                   FontFamily="Cascadia Mono, Consolas" FontSize="10"
                   FontWeight="Bold" CharacterSpacing="50"/>
    </Border>

</UserControl>
