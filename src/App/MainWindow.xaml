<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Alan.Photorganizer.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Alan.Photorganizer.App"
    xmlns:models="using:Alan.Photorganizer.App.Models"
    Title="Photorganizer">

    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: Title Bar ═══ -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="{ThemeResource TitleBarBrush}">
            <StackPanel Orientation="Horizontal" Spacing="7"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE80F;" FontSize="13" Foreground="{ThemeResource TextDimBrush}" FontFamily="Segoe Fluent Icons"/>
                <TextBlock Text="Photorganizer" FontSize="12.5" FontWeight="Medium"
                           Foreground="{ThemeResource TextDimBrush}"/>
            </StackPanel>
            <Border Height="1" VerticalAlignment="Bottom" Background="{ThemeResource AppBorderBrush}"/>
        </Grid>

        <!-- ═══ Row 1: Toolbar ═══ -->
        <Grid Grid.Row="1" Padding="20, 14" Background="{ThemeResource ToolbarBrush}" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Folder Picker -->
            <Button Grid.Column="0" x:Name="FolderPickBtn" Click="FolderPick_Click"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                    CornerRadius="7" Padding="13,8"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontSize="14" Opacity="0.4"
                              Foreground="{ThemeResource TextDimBrush}" Margin="0,0,9,0"/>
                    <TextBlock Grid.Column="1" x:Name="FolderPath" Text="Choose a folder..."
                               FontFamily="Cascadia Mono, Consolas" FontSize="12.5"
                               Foreground="{ThemeResource TextMutedBrush}"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                </Grid>
            </Button>

            <!-- Format Dropdown -->
            <Button Grid.Column="1"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                    CornerRadius="7" Padding="12,8" MinWidth="152">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE787;" FontSize="13" Opacity="0.4"
                              Foreground="{ThemeResource TextDimBrush}" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" x:Name="FormatLabel" Text="yyyy-MM-dd"
                               FontFamily="Cascadia Mono, Consolas" FontSize="12.5"
                               Foreground="{ThemeResource TextDimBrush}" VerticalAlignment="Center"/>
                    <FontIcon Grid.Column="2" Glyph="&#xE70D;" FontSize="10" Opacity="0.4"
                              Foreground="{ThemeResource TextDimBrush}" Margin="8,0,0,0"/>
                </Grid>
                <Button.Flyout>
                    <MenuFlyout x:Name="FormatFlyout" Placement="Bottom">
                        <RadioMenuFlyoutItem Text="yyyy-MM-dd" GroupName="FolderFormat" IsChecked="True" Click="FormatItem_Click"/>
                        <RadioMenuFlyoutItem Text="yyyy-M-d" GroupName="FolderFormat" Click="FormatItem_Click"/>
                        <RadioMenuFlyoutItem Text="dd-MM-yyyy" GroupName="FolderFormat" Click="FormatItem_Click"/>
                        <RadioMenuFlyoutItem Text="d-M-yyyy" GroupName="FolderFormat" Click="FormatItem_Click"/>
                        <RadioMenuFlyoutItem Text="MM-dd-yyyy" GroupName="FolderFormat" Click="FormatItem_Click"/>
                        <RadioMenuFlyoutItem Text="M-d-yyyy" GroupName="FolderFormat" Click="FormatItem_Click"/>
                        <RadioMenuFlyoutItem Text="yyyy.MM.dd" GroupName="FolderFormat" Click="FormatItem_Click"/>
                        <RadioMenuFlyoutItem Text="yyyy.M.d" GroupName="FolderFormat" Click="FormatItem_Click"/>
                        <RadioMenuFlyoutItem Text="dd.MM.yyyy" GroupName="FolderFormat" Click="FormatItem_Click"/>
                        <RadioMenuFlyoutItem Text="d.M.yyyy" GroupName="FolderFormat" Click="FormatItem_Click"/>
                        <RadioMenuFlyoutItem Text="MM.dd.yyyy" GroupName="FolderFormat" Click="FormatItem_Click"/>
                        <RadioMenuFlyoutItem Text="M.d.yyyy" GroupName="FolderFormat" Click="FormatItem_Click"/>
                        <RadioMenuFlyoutItem Text="yyyy MMM" GroupName="FolderFormat" Click="FormatItem_Click"/>
                        <MenuFlyoutSeparator/>
                        <RadioMenuFlyoutItem x:Name="CustomFormatItem" Text="Custom..." GroupName="FolderFormat" Click="CustomFormatItem_Click"/>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <!-- Organize Button -->
            <Button Grid.Column="2" x:Name="OrganizeBtn" Click="Organize_Click" IsEnabled="False"
                    Background="{ThemeResource PrimaryButtonBrush}"
                    Foreground="{ThemeResource PrimaryButtonText}"
                    CornerRadius="7" Padding="18,8">
                <StackPanel Orientation="Horizontal" Spacing="7">
                    <FontIcon Glyph="&#xE8CB;" FontSize="13"/>
                    <TextBlock Text="Organize" FontWeight="SemiBold" FontSize="13"/>
                </StackPanel>
            </Button>

            <Border Height="1" VerticalAlignment="Bottom" Background="{ThemeResource AppBorderBrush}"
                    Grid.ColumnSpan="3" Margin="-20, 0, -20, -14"/>
        </Grid>

        <!-- ═══ Row 2: Progress Strip ═══ -->
        <Grid Grid.Row="2" x:Name="ProgressStrip" Visibility="Collapsed"
              Padding="20,10" Background="{ThemeResource ToolbarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top row: status + details -->
            <Grid Grid.Row="0" Margin="0,0,0,7">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <ProgressRing Width="13" Height="13" IsActive="True"
                                  Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock x:Name="ProgressLabel" Text="Scanning folder..."
                               FontSize="12.5" FontWeight="Medium"
                               Foreground="{ThemeResource AppTextBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="ProgressDetail" FontSize="11.5"
                               FontFamily="Cascadia Mono, Consolas"
                               Foreground="{ThemeResource TextMutedBrush}"/>
                    <TextBlock x:Name="ProgressPct" FontSize="11.5" FontWeight="SemiBold"
                               FontFamily="Cascadia Mono, Consolas"
                               Foreground="{ThemeResource AccentBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Progress bar -->
            <ProgressBar Grid.Row="1" x:Name="ProgressBar"
                         Height="3" CornerRadius="1.5"
                         Foreground="{ThemeResource ProgressGradient}"
                         Background="{ThemeResource ProgressTrackBrush}"
                         IsIndeterminate="True"/>

            <Border Height="1" VerticalAlignment="Bottom" Background="{ThemeResource AppBorderBrush}"
                    Grid.RowSpan="2" Margin="-20,0"/>
        </Grid>

        <!-- ═══ Row 3: Stats & Filter Bar ═══ -->
        <Grid Grid.Row="3" Padding="20,8" Background="{ThemeResource StatsRowBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: filter chips -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <!-- All chip -->
                <Button x:Name="ChipAll" Click="ChipAll_Click"
                        Style="{StaticResource ChipButtonStyle}"
                        CornerRadius="13" Padding="10,3" Height="26"
                        PointerEntered="Chip_PointerEntered" PointerExited="Chip_PointerExited"
                        BorderBrush="{ThemeResource AppBorderBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="All" FontFamily="Cascadia Mono, Consolas" FontSize="11.5"
                                   Foreground="{ThemeResource TextMutedBrush}"/>
                        <TextBlock x:Name="ChipAllVal" Text="247" FontFamily="Cascadia Mono, Consolas"
                                   FontSize="11.5" FontWeight="Medium"
                                   Foreground="{ThemeResource AccentBrush}" Visibility="Collapsed"/>
                    </StackPanel>
                </Button>

                <!-- Divider -->
                <Border Width="1" Height="14" Background="{ThemeResource AppBorderBrush}" Margin="2,0"/>

                <!-- JPG -->
                <Button x:Name="ChipJpg" Click="ChipFmt_Click" Tag="JPG"
                        Style="{StaticResource ChipButtonStyle}"
                        CornerRadius="13" Padding="10,3" Height="26"
                        PointerEntered="Chip_PointerEntered" PointerExited="Chip_PointerExited"
                        BorderBrush="{ThemeResource AppBorderBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="JPG" FontFamily="Cascadia Mono, Consolas" FontSize="11.5"/>
                        <TextBlock x:Name="CntJpg" Text="128" FontFamily="Cascadia Mono, Consolas"
                                   FontSize="11.5" FontWeight="Medium" Visibility="Collapsed"/>
                    </StackPanel>
                </Button>

                <!-- HEIC -->
                <Button x:Name="ChipHeic" Click="ChipFmt_Click" Tag="HEIC"
                        Style="{StaticResource ChipButtonStyle}"
                        CornerRadius="13" Padding="10,3" Height="26"
                        PointerEntered="Chip_PointerEntered" PointerExited="Chip_PointerExited"
                        BorderBrush="{ThemeResource AppBorderBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="HEIC" FontFamily="Cascadia Mono, Consolas" FontSize="11.5"/>
                        <TextBlock x:Name="CntHeic" Text="61" FontFamily="Cascadia Mono, Consolas"
                                   FontSize="11.5" FontWeight="Medium" Visibility="Collapsed"/>
                    </StackPanel>
                </Button>

                <!-- PNG -->
                <Button x:Name="ChipPng" Click="ChipFmt_Click" Tag="PNG"
                        Style="{StaticResource ChipButtonStyle}"
                        CornerRadius="13" Padding="10,3" Height="26"
                        PointerEntered="Chip_PointerEntered" PointerExited="Chip_PointerExited"
                        BorderBrush="{ThemeResource AppBorderBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="PNG" FontFamily="Cascadia Mono, Consolas" FontSize="11.5"/>
                        <TextBlock x:Name="CntPng" Text="34" FontFamily="Cascadia Mono, Consolas"
                                   FontSize="11.5" FontWeight="Medium" Visibility="Collapsed"/>
                    </StackPanel>
                </Button>

                <!-- MOV -->
                <Button x:Name="ChipMov" Click="ChipFmt_Click" Tag="MOV"
                        Style="{StaticResource ChipButtonStyle}"
                        CornerRadius="13" Padding="10,3" Height="26"
                        PointerEntered="Chip_PointerEntered" PointerExited="Chip_PointerExited"
                        BorderBrush="{ThemeResource AppBorderBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="MOV" FontFamily="Cascadia Mono, Consolas" FontSize="11.5"/>
                        <TextBlock x:Name="CntMov" Text="24" FontFamily="Cascadia Mono, Consolas"
                                   FontSize="11.5" FontWeight="Medium" Visibility="Collapsed"/>
                    </StackPanel>
                </Button>

                <!-- Divider -->
                <Border Width="1" Height="14" Background="{ThemeResource AppBorderBrush}" Margin="2,0"/>

                <!-- Groups (read-only) -->
                <Border x:Name="ChipGroups" Visibility="Collapsed"
                        CornerRadius="13" Padding="10,3" Height="26"
                        Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="Groups" FontFamily="Cascadia Mono, Consolas" FontSize="11.5"
                                   Foreground="{ThemeResource TextMutedBrush}"/>
                        <TextBlock x:Name="ChipGroupsVal" Text="0" FontFamily="Cascadia Mono, Consolas" FontSize="11.5"
                                   FontWeight="Medium" Foreground="{ThemeResource SuccessBrush}"/>
                    </StackPanel>
                </Border>

                <!-- No EXIF (read-only) -->
                <Border x:Name="ChipNoExif" Visibility="Collapsed"
                        CornerRadius="13" Padding="10,3" Height="26"
                        Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="No EXIF" FontFamily="Cascadia Mono, Consolas" FontSize="11.5"
                                   Foreground="{ThemeResource TextMutedBrush}"/>
                        <TextBlock x:Name="ChipNoExifVal" Text="0" FontFamily="Cascadia Mono, Consolas" FontSize="11.5"
                                   FontWeight="Medium" Foreground="{ThemeResource WarningBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right: theme toggle -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Border Width="1" Height="14" Background="{ThemeResource AppBorderBrush}" Margin="2,0"/>
                <ToggleButton x:Name="ThemeToggle" IsChecked="{x:Bind IsDarkTheme, Mode=OneTime}"
                              Click="ThemeToggle_Click"
                              Style="{StaticResource ThemeToggleButtonStyle}"
                              VerticalAlignment="Center"/>
            </StackPanel>

            <Border Height="1" VerticalAlignment="Bottom" Background="{ThemeResource AppBorderBrush}"
                    Grid.ColumnSpan="3" Margin="-20,0,-20,-8"/>
        </Grid>

        <!-- ═══ Row 4: File Table ═══ -->
        <Grid Grid.Row="4">
            <!-- Table Header -->
            <Grid x:Name="TableHeader" Height="38" VerticalAlignment="Top"
                  Background="{ThemeResource TableHeaderBrush}" Padding="0"
                  Canvas.ZIndex="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="22*"/>
                    <ColumnDefinition Width="24*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="FILE NAME" Padding="20,0,16,0"
                           VerticalAlignment="Center" CharacterSpacing="100"
                           FontSize="10.5" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextMutedBrush}"/>
                <TextBlock Grid.Column="1" Text="FORMAT" Padding="16,0"
                           VerticalAlignment="Center" CharacterSpacing="100"
                           FontSize="10.5" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextMutedBrush}"/>
                <TextBlock Grid.Column="2" Text="CAPTURE TIME" Padding="16,0"
                           VerticalAlignment="Center" CharacterSpacing="100"
                           FontSize="10.5" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextMutedBrush}"/>
                <TextBlock Grid.Column="3" Text="DESTINATION FOLDER" Padding="16,0"
                           VerticalAlignment="Center" CharacterSpacing="100"
                           FontSize="10.5" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextMutedBrush}"/>
                <TextBlock Grid.Column="4" Text="STATUS" Padding="16,0,20,0"
                           VerticalAlignment="Center" CharacterSpacing="100"
                           FontSize="10.5" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextMutedBrush}"/>
                <Border Height="1" VerticalAlignment="Bottom" Background="{ThemeResource AppBorderBrush}"
                        Grid.ColumnSpan="5"/>
            </Grid>

            <!-- File List -->
            <ListView x:Name="FileList" Margin="0,38,0,0" SelectionMode="None"
                      IsItemClickEnabled="False">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="MinHeight" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:FileItem">
                        <Grid Padding="0,9" BorderBrush="{ThemeResource RowBorderBrush}" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="22*"/>
                                <ColumnDefinition Width="24*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <!-- File Name -->
                            <TextBlock Grid.Column="0" Text="{x:Bind Name}" Padding="20,0,16,0"
                                       FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                       Foreground="{ThemeResource AppTextBrush}"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                       MaxWidth="240"/>

                            <!-- Format Badge -->
                            <local:FormatBadge Grid.Column="1" Format="{x:Bind Format}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center"
                                               Margin="16,0"/>

                            <!-- Capture Time -->
                            <TextBlock Grid.Column="2" Text="{x:Bind CaptureTime, Mode=OneWay}" Padding="16,0"
                                       FontFamily="Cascadia Mono, Consolas" FontSize="11.5"
                                       Foreground="{ThemeResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>

                            <!-- Destination Folder -->
                            <Grid Grid.Column="3" Padding="16,0" VerticalAlignment="Center">
                                <!-- Valid date: folder icon + folder name -->
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            Visibility="{x:Bind HasExif, Mode=OneWay}">
                                    <FontIcon Glyph="&#xED41;" FontSize="10"
                                              Foreground="{ThemeResource TextMutedBrush}" Opacity="0.55"/>
                                    <TextBlock Text="{x:Bind DestFolder, Mode=OneWay}"
                                               Foreground="{ThemeResource AppTextBrush}"
                                               FontFamily="Cascadia Mono, Consolas" FontSize="11.5"/>
                                </StackPanel>
                                <!-- No EXIF: warning icon + dash -->
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            Visibility="{x:Bind NoExif, Mode=OneWay}">
                                    <FontIcon Glyph="&#xE946;" FontSize="10"
                                              Foreground="{ThemeResource WarningBrush}" Opacity="0.45"/>
                                    <TextBlock Text="{x:Bind DestFolder, Mode=OneWay}"
                                               Foreground="{ThemeResource WarningBrush}"
                                               FontFamily="Cascadia Mono, Consolas" FontSize="11.5"/>
                                </StackPanel>
                            </Grid>

                            <!-- Status Pill -->
                            <local:StatusPill Grid.Column="4" Status="{x:Bind StatusText, Mode=OneWay}"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="16,0,20,0"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty State -->
            <Grid x:Name="EmptyState" Margin="0,38,0,0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                    <FontIcon Glyph="&#xE8B7;" FontSize="32" Opacity="0.25"
                              Foreground="{ThemeResource TextMutedBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Choose a folder to get started" FontSize="12.5" Opacity="0.45"
                               Foreground="{ThemeResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
