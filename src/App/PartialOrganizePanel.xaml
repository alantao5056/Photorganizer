<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Alan.Photorganizer.App.PartialOrganizePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Padding="20,14,20,18">
        <TextBlock FontSize="12.5" Foreground="{ThemeResource TextDimBrush}"
                   TextWrapping="Wrap" LineHeight="20">
            This operation will only organize the following formats:
        </TextBlock>
        <ItemsControl x:Name="BadgeList" Margin="0,10,0,10">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="5"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
        <TextBlock FontSize="12.5" Foreground="{ThemeResource TextDimBrush}"
                   TextWrapping="Wrap" LineHeight="20">
            Files of unselected types will be left in place. Do you want to continue?
        </TextBlock>
    </StackPanel>

</UserControl>
