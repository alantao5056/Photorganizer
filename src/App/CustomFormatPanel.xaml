<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Alan.Photorganizer.App.CustomFormatPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <!-- FORMAT PATTERN label -->
        <TextBlock Text="FORMAT PATTERN"
                   FontSize="10.5" FontWeight="SemiBold"
                   CharacterSpacing="80"
                   Opacity="0.55"
                   Margin="0,0,0,7"/>

        <!-- Input with inline preview -->
        <Border x:Name="InputBorder"
                BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1.5" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="FormatBox"
                         Grid.Column="0"
                         PlaceholderText="e.g. yyyy-MM-dd"
                         FontFamily="Cascadia Mono, Consolas" FontSize="13"
                         BorderThickness="0"
                         Padding="10,8,10,8"
                         IsSpellCheckEnabled="False"
                         IsTextPredictionEnabled="False"
                         TextChanged="FormatBox_TextChanged">
                    <TextBox.Resources>
                        <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                    </TextBox.Resources>
                </TextBox>

                <Border Grid.Column="1"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1,0,0,0"
                        Padding="12,0"
                        Background="{ThemeResource SystemControlBackgroundListLowBrush}">
                    <TextBlock x:Name="PreviewBlock"
                               FontFamily="Cascadia Mono, Consolas"
                               FontSize="11" Opacity="0.6"
                               VerticalAlignment="Center"
                               Text="Preview: "/>
                </Border>
            </Grid>
        </Border>

        <!-- Token Reference Box -->
        <Border Margin="0,14,0,0"
                Padding="14,12"
                BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1" CornerRadius="6"
                Background="{ThemeResource SystemControlBackgroundListLowBrush}">
            <StackPanel>
                <TextBlock Text="FORMAT TOKENS — CLICK TO INSERT"
                           FontSize="10" FontWeight="SemiBold"
                           CharacterSpacing="80"
                           Opacity="0.55"
                           Margin="0,0,0,10"/>

                <!-- Year -->
                <TextBlock Text="YEAR" FontSize="9.5" FontWeight="SemiBold"
                           CharacterSpacing="100" Opacity="0.45"
                           Margin="0,0,0,4"/>
                <Grid ColumnSpacing="8" RowSpacing="3" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7">
                        <HyperlinkButton x:Name="Token_yyyy" Content="yyyy" Click="Token_Click" Padding="0" FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
                        <TextBlock Text="Full year (2024)" FontSize="10.5" Opacity="0.55" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7">
                        <HyperlinkButton x:Name="Token_yy" Content="yy" Click="Token_Click" Padding="0" FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
                        <TextBlock Text="Two-digit year (24)" FontSize="10.5" Opacity="0.55" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Month -->
                <TextBlock Text="MONTH" FontSize="9.5" FontWeight="SemiBold"
                           CharacterSpacing="100" Opacity="0.45"
                           Margin="0,0,0,4"/>
                <Grid ColumnSpacing="8" RowSpacing="3" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="7">
                        <HyperlinkButton x:Name="Token_MMMM" Content="MMMM" Click="Token_Click" Padding="0" FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
                        <TextBlock Text="Full name (March)" FontSize="10.5" Opacity="0.55" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="7">
                        <HyperlinkButton x:Name="Token_MMM" Content="MMM" Click="Token_Click" Padding="0" FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
                        <TextBlock Text="Abbreviated (Mar)" FontSize="10.5" Opacity="0.55" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="7">
                        <HyperlinkButton x:Name="Token_MM" Content="MM" Click="Token_Click" Padding="0" FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
                        <TextBlock Text="Two-digit (03)" FontSize="10.5" Opacity="0.55" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="7">
                        <HyperlinkButton x:Name="Token_M" Content="M" Click="Token_Click" Padding="0" FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
                        <TextBlock Text="No leading zero (3)" FontSize="10.5" Opacity="0.55" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Day -->
                <TextBlock Text="DAY" FontSize="9.5" FontWeight="SemiBold"
                           CharacterSpacing="100" Opacity="0.45"
                           Margin="0,0,0,4"/>
                <Grid ColumnSpacing="8" RowSpacing="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="7">
                        <HyperlinkButton x:Name="Token_dddd" Content="dddd" Click="Token_Click" Padding="0" FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
                        <TextBlock Text="Full name (Monday)" FontSize="10.5" Opacity="0.55" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="7">
                        <HyperlinkButton x:Name="Token_ddd" Content="ddd" Click="Token_Click" Padding="0" FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
                        <TextBlock Text="Abbreviated (Mon)" FontSize="10.5" Opacity="0.55" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="7">
                        <HyperlinkButton x:Name="Token_dd" Content="dd" Click="Token_Click" Padding="0" FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
                        <TextBlock Text="Two-digit (05)" FontSize="10.5" Opacity="0.55" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="7">
                        <HyperlinkButton x:Name="Token_d" Content="d" Click="Token_Click" Padding="0" FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
                        <TextBlock Text="No leading zero (5)" FontSize="10.5" Opacity="0.55" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Invalid characters hint -->
        <TextBlock Text="Invalid folder characters: \ / : * &quot; &lt; &gt; |"
                   FontSize="11" Opacity="0.45"
                   Margin="0,8,0,0"/>
    </StackPanel>

</UserControl>
