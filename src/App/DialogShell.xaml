<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Alan.Photorganizer.App.DialogShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- Backdrop -->
        <Border Background="#59000000"/>

        <!-- Dialog Card -->
        <Border x:Name="Card"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                CornerRadius="14"
                Background="{ThemeResource DialogBackgroundBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1">
            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>
            <StackPanel>
                <!-- Header -->
                <Grid Padding="20,18,20,14"
                      BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="IconBorder" Grid.Column="0"
                            Width="34" Height="34" CornerRadius="9" Margin="0,0,11,0"
                            BorderThickness="1">
                        <FontIcon x:Name="HeaderIcon" FontSize="14"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleBlock" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource AppTextBrush}"/>
                        <TextBlock x:Name="SubtitleBlock" FontSize="11.5"
                                   Foreground="{ThemeResource TextMutedBrush}"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Body -->
                <ContentPresenter x:Name="BodyPresenter"/>

                <!-- Footer -->
                <Grid x:Name="FooterGrid" Padding="20,14"
                      BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,1,0,0"
                      Background="{ThemeResource DialogFooterBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter x:Name="FooterExtraPresenter" Grid.Column="0"
                                      VerticalAlignment="Center"/>
                    <Button x:Name="CancelBtn" Grid.Column="1" Content="Cancel"
                            Click="CancelBtn_Click"
                            Background="{ThemeResource SurfaceBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                            CornerRadius="7" Padding="18,8" FontSize="12.5"
                            Foreground="{ThemeResource TextMutedBrush}"
                            Margin="0,0,8,0"/>
                    <Button x:Name="PrimaryBtn" Grid.Column="2"
                            Click="PrimaryBtn_Click"
                            Background="{ThemeResource PrimaryButtonBrush}"
                            Foreground="{ThemeResource PrimaryButtonText}"
                            CornerRadius="7" Padding="18,8" FontSize="12.5" FontWeight="SemiBold"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>
